# Optional: use Groq's hosted Llama 3.3 70B for answer generation.
# Get a free key at https://console.groq.com - without it, a local
# flan-t5-base model is used (slower, lower quality, but fully offline).
GROQ_API_KEY=

# Force a provider instead of auto-detect: "groq" or "local"
RAG_LLM_PROVIDER=auto
